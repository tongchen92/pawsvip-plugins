{
  "mcpServers": {
    "qbo": {
      "type": "http",
      "url": "https://app.pawsvip.com/api/qbo/mcp",
      "headers": {
        "Authorization": "Bearer ${user_config.qbo_token}"
      }
    },
    "adsagent": {
      "type": "http",
      "url": "https://www.adsagent.org/api/mcp",
      "headers": {
        "Authorization": "Bearer ${user_config.adsagent_token}"
      }
    }
  }
}
